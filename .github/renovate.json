{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "pre-commit": {
    "enabled": true
  },
  "terraform": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "tflint_version input in validate.yml",
      "fileMatch": ["\\.github/workflows/validate\\.yml"],
      "matchStrings": ["tflint_version:\\s+(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "terraform-linters/tflint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "OPA version in validate.yml",
      "fileMatch": ["\\.github/workflows/validate\\.yml"],
      "matchStrings": ["OPA_VERSION:\\s+\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "open-policy-agent/opa",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "ArgoCD Helm chart version in variables.tf",
      "fileMatch": ["stacks/argo-cd/variables\\.tf"],
      "matchStrings": [
        "default\\s+=\\s+\"(?<currentValue>[^\"]+)\"\\s*\\n}\\s*$"
      ],
      "depNameTemplate": "argo-cd",
      "packageNameTemplate": "argoproj/argo-helm",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^argo-cd-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "kube-prometheus-stack Helm chart version in variables.tf",
      "fileMatch": ["stacks/prometheus/variables\\.tf"],
      "matchStrings": [
        "prometheus_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "kube-prometheus-stack",
      "packageNameTemplate": "prometheus-community/helm-charts",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^kube-prometheus-stack-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Loki Helm chart version in variables.tf",
      "fileMatch": ["stacks/prometheus/variables\\.tf"],
      "matchStrings": [
        "loki_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "loki",
      "packageNameTemplate": "grafana/helm-charts",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^loki-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Grafana Alloy Helm chart version in variables.tf",
      "fileMatch": ["stacks/prometheus/variables\\.tf"],
      "matchStrings": [
        "alloy_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "alloy",
      "packageNameTemplate": "grafana/helm-charts",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^alloy-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "argocd-apps Helm chart version in variables.tf",
      "fileMatch": ["stacks/argo-cd/variables\\.tf"],
      "matchStrings": [
        "argocd_apps_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "argocd-apps",
      "packageNameTemplate": "argoproj/argo-helm",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^argocd-apps-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "AWS Load Balancer Controller Helm chart version in variables.tf",
      "fileMatch": ["stacks/eks-addons/variables\\.tf"],
      "matchStrings": [
        "aws_lb_controller_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "aws-load-balancer-controller",
      "packageNameTemplate": "kubernetes-sigs/aws-load-balancer-controller",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^helm-chart-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "cluster-autoscaler Helm chart version in variables.tf",
      "fileMatch": ["stacks/eks-addons/variables\\.tf"],
      "matchStrings": [
        "cluster_autoscaler_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "cluster-autoscaler",
      "packageNameTemplate": "kubernetes/autoscaler",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^cluster-autoscaler-chart-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "external-secrets Helm chart version in variables.tf",
      "fileMatch": ["stacks/eks-addons/variables\\.tf"],
      "matchStrings": [
        "external_secrets_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "external-secrets",
      "packageNameTemplate": "external-secrets/external-secrets",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^helm-chart-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Kyverno Helm chart version in variables.tf",
      "fileMatch": ["stacks/kyverno/variables\\.tf"],
      "matchStrings": [
        "kyverno_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "kyverno",
      "packageNameTemplate": "kyverno/kyverno",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^kyverno-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "kyverno-policies Helm chart version in variables.tf",
      "fileMatch": ["stacks/kyverno/variables\\.tf"],
      "matchStrings": [
        "kyverno_policies_chart_version[\\s\\S]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "kyverno-policies",
      "packageNameTemplate": "kyverno/kyverno",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^kyverno-policies-(?<version>.*)$"
    }
  ]
}
