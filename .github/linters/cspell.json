{
  "version": "0.2",
  "language": "en",
  "dictionaries": ["en_US", "en-gb", "softwareTerms", "bash", "aws", "k8s", "terraform"],
  "ignorePaths": [
    ".terraform/",
    "**/.terraform.lock.hcl",
    "megalinter-reports",
    "*megalinter_file_names_cspell.txt"
  ],
  "words": [
    "spacelift",
    "spacectl",
    "autodeploy",
    "rego",
    "sarif",
    "sprintf",
    "alertmanager",
    "coredns",
    "eksbuild",
    "imds",
    "coip",
    "ebscsi",
    "ingester",
    "karpenter",
    "kubeconform",
    "kubeseal",
    "misconfig",
    "misconfigs",
    "tflintignore",
    "rtype",
    "apiserver",
    "applicationset",
    "awscli",
    "gpgsign",
    "keyid",
    "signingkey",
    "fearfactor",
    "homelab",
    "clustersecretstore",
    "externalsecret",
    "creds",
    "ltrimstr",
    "rtrimstr",
    "commitlint",
    "amannn",
    "awscloudwatch",
    "otelcol"
  ],
  "overrides": [
    {
      "filename": "**/*.tf",
      "ignoreRegExpList": [
        "arn:aws:[\\w:/-]+",
        "[a-z]+\\.[a-z_]+\\.[a-z_]+",
        "[0-9a-f]{40}"
      ]
    },
    {
      "filename": "**/*.rego",
      "ignoreRegExpList": [
        "[a-z_]+\\.[a-z_]+"
      ]
    }
  ]
}
