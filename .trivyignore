# Trivy misconfig ignore list — intentional design decisions
# Justifications are kept here so decisions are reviewable in code review.

# EKS public endpoint is intentionally enabled; access is restricted via the
# public_access_cidrs variable — not hardcoded to 0.0.0.0/0.
AVD-AWS-0040

# EKS cluster security group unrestricted egress is required for nodes to reach
# ECR, S3, and AWS APIs. Restricting egress breaks cluster functionality.
AVD-AWS-0104

# Public subnets require map_public_ip_on_launch = true for NAT Gateway EIPs
# and internet-facing load balancers. This is expected behaviour for public subnets.
AVD-AWS-0164

# CloudWatch log groups (EKS control plane, VPC flow logs) use AWS-managed encryption
# by default. A customer-managed KMS CMK would add $1/key/month per environment with
# no material security benefit for this test environment — logs are not PII/PCI-scoped.
AVD-AWS-0017

# Kyverno policy test fixtures are intentionally misconfigured — each exists to
# trigger a specific policy violation and must not pass the checks it is designed
# to fail. Scoped to the test resources directory so real workload manifests
# elsewhere in the repo still receive full trivy coverage.
KSV-0011 path:stacks/kyverno/tests/resources/
KSV-0012 path:stacks/kyverno/tests/resources/
KSV-0013 path:stacks/kyverno/tests/resources/
KSV-0015 path:stacks/kyverno/tests/resources/
KSV-0016 path:stacks/kyverno/tests/resources/
KSV-0018 path:stacks/kyverno/tests/resources/
KSV-0020 path:stacks/kyverno/tests/resources/
KSV-0021 path:stacks/kyverno/tests/resources/
KSV-0030 path:stacks/kyverno/tests/resources/
KSV-0104 path:stacks/kyverno/tests/resources/
KSV-0105 path:stacks/kyverno/tests/resources/
KSV-0125 path:stacks/kyverno/tests/resources/

# NetworkPolicy egress to 0.0.0.0/0 is intentional in three policies:
#   - argocd/allow-https-egress: kube-apiserver + Git remotes (variable IPs, port 443 only)
#   - prometheus/allow-https-egress: kube-apiserver + CloudWatch (variable IPs, port 443 only)
#   - prometheus/allow-node-scrape-egress: node-exporter (hostNetwork, node IPs vary, ports 9100/10250 only)
# Port-scoped egress limits blast radius; full CIDR restriction is not feasible
# because target IPs are assigned dynamically by AWS and cannot be enumerated at authoring time.
KUBE-0002
